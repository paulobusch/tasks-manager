{
  "compilerOptions": {
    "outDir": "dist",
    "strictNullChecks": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@settings": ["settings.json"],
      "@database": ["src/database.ts"],
      "@bases/*": ["src/utils/bases/*"],
      "@tests/*": ["tests/*"],
      "@models/*": ["src/models/*"],
      "@hashing/*": ["src/utils/hashing/*"],
      "@decorators/*": ["src/utils/decorators/*"],
      "@validators/*": ["src/utils/validators/*"],
      "@metadata/*": ["src/utils/metadata/*"],
      "@enums/*": ["src/utils/enums/*"],
      "@handlers/*": ["src/utils/handlers/*"],
      "@interfaces/*": ["src/utils/interfaces/*"],
      "@results/*": ["src/utils/results/*"],
      "@routers/*": ["src/utils/routers/*"]
    }
  }
}
